// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{
  // Application
  "diff_view_style": "unified",
  "auto_update": false,
  "cli_default_open_behavior": "existing_window",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // Appearance — theme & icons
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "theme_overrides": {
    "Catppuccin Mocha": {
      "border": "#313244",
      "border.variant": "#313244",
      "title_bar.background": "#1e1e2e",
      "status_bar.background": "#1e1e2e",
      // "panel.background": "#232332",
      // "panel.focused_border": "#232332",
    },
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "text_rendering_mode": "platform_default",

  // Editor — font & cursor
  "buffer_font_family": "MonoLisa Meme",
  "cursor_blink": false,

  // Editor — line numbers & gutter
  "relative_line_numbers": "enabled",
  "gutter": { "min_line_number_digits": 1 },
  "indent_guides": { "enabled": false },

  // Editor — behavior
  "tab_size": 2,
  // "wrap_guides": [120],
  "vertical_scroll_margin": 10,
  "sticky_scroll": {
    "enabled": true,
  },
  "inline_code_actions": false,
  "extend_comment_on_newline": false,
  "code_actions_on_format": {
    "source.fixAll.eslint": true,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },

  // Vim
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "toggle_relative_line_numbers": true,
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 0,
  },

  // UI — title bar
  "title_bar": {
    "show_sign_in": false,
    "show_user_menu": false,
  },

  // UI — tabs, scrollbar, minimap, toolbar
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "scrollbar": { "show": "never" },
  "minimap": { "show": "never" },
  "toolbar": {
    "quick_actions": false,
  },

  // UI — panels
  "close_panel_on_toggle": true,
  "project_panel": {
    "button": false,
    "scrollbar": null,
    "default_width": 600,
    "hide_root": true,
    "starts_open": false,
    "dock": "right",
  },
  "collaboration_panel": { "button": false },
  "outline_panel": { "button": false },
  "git_panel": { "button": false },
  "debugger": { "button": false },
  "terminal": { "button": false },
  "agent": { "button": false },
  "search": { "button": false },

  // UI — layout
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },
  "file_finder": {
    "modal_max_width": "medium",
  },

  // Agent
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },

  "command_aliases": {
    "zlog": "zed::OpenLog",
    "newf": "workspace::NewFile",
    "diffs": "editor::ToggleSelectedDiffHunks",
    "crp": "workspace::CopyRelativePath",
    "cpp": "workspace::CopyPath",
    "reveal": "editor::RevealInFileManager",
    "clank": "editor::CancelLanguageServerWork",
    "bdiff": "git::BranchDiff",
  },

  "edit_predictions": {
    "allow_data_collection": "no",
  },
}
